---
import fs from 'node:fs';
import EndusersLayout from '../layouts/EndusersLayout.astro';
import { renderCard } from '../lib/member-renderer';
import { selectHeroes } from '../lib/heroes';
import type { SafeMember } from '../lib/member-renderer';

const HERO_TIER_COLORS: Record<string, string> = {
  'Platinum': '#E5E4E2',
  'Gold': '#FFB300',
  'Silver': '#C0C0C0',
  'End User': '#0086FF',
  'Academic': '#7B2FBE',
  'Nonprofit': '#00A86B',
};

let members: SafeMember[] = [];
try {
  const raw = fs.readFileSync('src/data/members.json', 'utf-8');
  members = JSON.parse(raw) as SafeMember[];
} catch {
  // graceful degradation on fresh clone
}

const endUserCount = members.filter(m => m.isEndUser).length;
const totalFunding = members.reduce((sum, m) => sum + (m.totalFunding ?? 0), 0);
const industries = [...new Set(members.flatMap(m => m.industries ?? []).filter(Boolean))].sort();
const countries = [...new Set(members.map(m => m.country).filter(Boolean))].sort() as string[];
const heroes = selectHeroes(members);

const STATIC_COUNT = 30;
const staticMembers = members.slice(0, STATIC_COUNT);
const heroEntries = [
  { key: 'endUser', label: 'End User Spotlight', member: heroes.endUser },
  { key: 'platinum', label: 'Platinum Member', member: heroes.platinum },
  { key: 'recentlyJoined', label: 'Recently Joined', member: heroes.recentlyJoined },
  { key: 'community', label: 'Academic / Nonprofit', member: heroes.community },
].filter(h => h.member !== null) as { key: string; label: string; member: SafeMember }[];
---
<EndusersLayout
  title="CNCF End Users"
  memberCount={members.length}
  endUserCount={endUserCount}
  totalFunding={totalFunding}
  industries={industries}
  countries={countries}
>
  <div slot="heroes">
    {heroEntries.length > 0 && (
      <section class="heroes-section" aria-label="Daily highlights">
        <div class="heroes-grid">
          {heroEntries.map(({ label, member }) => {
            const heroColor = HERO_TIER_COLORS[member.tier] ?? 'var(--color-cncf-blue)';
            return (
              <div class="hero-card" style={`--card-accent: ${heroColor}`}>
                {member.logoUrl && <img class="hero-logo" src={member.logoUrl} alt={`${member.name} logo`} width="48" height="48" loading="lazy" />}
                <div class="hero-content">
                  <div class="hero-label">{label}</div>
                  <a class="hero-name" href={member.homepageUrl || '#'} target="_blank" rel="noopener">{member.name}</a>
                  {member.description && <p class="hero-description">{member.description.slice(0, 80)}{member.description.length > 80 ? '...' : ''}</p>}
                  <div class="hero-meta">
                    <span class="hero-tier">{member.tier}</span>
                    {member.country && <span>{member.countryFlag} {member.country}</span>}
                    {member.industries?.[0] && <span>{member.industries[0]}</span>}
                  </div>
                </div>
              </div>
            );
          })}
        </div>
      </section>
    )}
  </div>

  {staticMembers.map(m => <Fragment set:html={renderCard(m)} />)}
</EndusersLayout>

<script>
  import { initSearch, searchMembers, getAllMembers } from '../lib/search';
  import { renderCard } from '../lib/member-renderer';
  import { initTabs, filterByTab } from '../lib/tabs';
  import { initKeyboard, tabFromNumber } from '../lib/keyboard';
  import { fireFountain, preloadOnHover, fireHearts } from '../lib/confetti';
  import type { TabId } from '../lib/tabs';

  const base = import.meta.env.BASE_URL;
  const grid = document.getElementById('members-grid')!;
  const noResults = document.getElementById('no-results')!;
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const searchCount = document.getElementById('search-count')!;
  const statShowing = document.getElementById('stat-showing')!;

  let allMembers: import('../lib/member-renderer').SafeMember[] = [];
  let currentTab: TabId = 'everyone';
  let currentQuery = '';
  let currentIndustry = '';
  let currentRegion = '';

  async function loadAllMembers() {
    try {
      const res = await fetch(`${base}/data/members.json`);
      allMembers = await res.json();
      initSearch(allMembers);
      applyFilters();
    } catch {
      // use static members already rendered
    }
  }

  function applyFilters() {
    let filtered = filterByTab(allMembers, currentTab);
    if (currentQuery.trim()) {
      const results = searchMembers(currentQuery);
      const slugSet = new Set(results.map(r => r.slug));
      filtered = filtered.filter(m => slugSet.has(m.slug));
    }
    if (currentIndustry) {
      filtered = filtered.filter(m => (m.industries ?? []).includes(currentIndustry));
    }
    if (currentRegion) {
      filtered = filtered.filter(m => m.country === currentRegion);
    }
    if (filtered.length === 0 && (currentQuery || currentTab !== 'everyone')) {
      grid.style.display = 'none';
      noResults.style.display = 'block';
      searchCount.textContent = '';
      statShowing.textContent = '0';
    } else {
      noResults.style.display = 'none';
      grid.style.display = '';
      grid.innerHTML = filtered.map(renderCard).join('\n');
      wireCardEvents();
      const label = String(filtered.length);
      statShowing.textContent = label;
      searchCount.textContent = currentQuery ? String(filtered.length) : '';
    }
  }

  initTabs((tabId) => { currentTab = tabId; applyFilters(); });

  searchInput?.addEventListener('input', () => {
    currentQuery = searchInput.value;
    applyFilters();
  });

  const visibleCards = () =>
    Array.from(document.querySelectorAll<HTMLElement>('.member-card, .hero-card'))
      .filter(c => c.offsetParent !== null && c.style.display !== 'none');

  let focusedIdx = -1;

  function resetFocus() {
    document.querySelectorAll('.keyboard-focused')
      .forEach(c => c.classList.remove('keyboard-focused'));
    focusedIdx = -1;
  }

  function focusCard(idx: number) {
    const all = visibleCards();
    if (all.length === 0) return;
    focusedIdx = Math.max(0, Math.min(idx, all.length - 1));
    all.forEach((c, i) => c.classList.toggle('keyboard-focused', i === focusedIdx));
    all[focusedIdx].scrollIntoView({ block: 'nearest', behavior: 'smooth' });
    const liveRegion = document.getElementById('kbd-live-region');
    if (liveRegion) {
      const name = all[focusedIdx].querySelector('.card-name, .member-name, .hero-name, h3, h4')?.textContent ?? '';
      liveRegion.textContent = `Focused: ${name}`;
    }
  }

  document.querySelectorAll('.section-link[data-tab]').forEach(btn => {
    btn.addEventListener('click', resetFocus);
  });

  initKeyboard({
    onSearch: () => searchInput?.focus(),
    onTheme: () => { const btn = document.getElementById('theme-toggle') as HTMLButtonElement; btn?.click(); },
    onTab: (n) => {
      const tab = tabFromNumber(n);
      const btn = document.querySelector(`.section-link[data-tab="${tab}"]`) as HTMLButtonElement;
      btn?.click();
    },
    onEscape: () => {
      if (searchInput && searchInput.value) {
        searchInput.value = '';
        currentQuery = '';
        applyFilters();
      }
      resetFocus();
    },
    onNext: () => { focusCard(focusedIdx + 1); },
    onPrev: () => { focusCard(focusedIdx - 1); },
    onOpenLink: () => {
      const all = visibleCards();
      const card = all[focusedIdx];
      const link = card?.querySelector('a[href]') as HTMLAnchorElement | null;
      if (link) { window.open(link.href, '_blank', 'noopener'); }
    },
    onSitePrev: () => { window.location.href = 'https://castrojo.github.io/projects-website/'; },
    onSiteNext: () => { window.location.href = 'https://castrojo.github.io/people-website/'; },
  });

  function wireCardEvents(): void {
    document.querySelectorAll<HTMLElement>('.member-card').forEach(card => {
      preloadOnHover(card);
      card.addEventListener('click', () => fireFountain(card));
    });
    document.querySelectorAll<HTMLElement>('.hero-card').forEach(card => {
      preloadOnHover(card);
      card.addEventListener('click', () => fireHearts(card));
    });
  }

  loadAllMembers();
  wireCardEvents();

  document.getElementById('industry-filter')?.addEventListener('change', (e) => {
    currentIndustry = (e.target as HTMLSelectElement).value;
    applyFilters();
  });

  document.getElementById('region-filter')?.addEventListener('change', (e) => {
    currentRegion = (e.target as HTMLSelectElement).value;
    applyFilters();
  });
</script>
