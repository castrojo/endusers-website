---
import fs from 'node:fs';
import EndusersLayout from '../layouts/EndusersLayout.astro';
import { renderCard, renderShowcaseCard } from '../lib/member-renderer';
import { renderChangelogEvent, type MemberEvent } from '../lib/changelog-renderer';
import { renderArchCard, type SafeArchitecture } from '../lib/architecture-renderer';
import { selectHeroSets } from '../lib/heroes';
import type { SafeMember } from '../lib/member-renderer';



let members: SafeMember[] = [];
try {
  const raw = fs.readFileSync('src/data/members.json', 'utf-8');
  members = JSON.parse(raw) as SafeMember[];
} catch {
  // graceful degradation on fresh clone
}

interface StaffPerson {
  handle?: string;
  name: string;
  imageUrl?: string;
  profileUrl?: string;
}
interface StaffSupport {
  maintainers?: StaffPerson[];
  [key: string]: StaffPerson[] | undefined;
}
let staffSupport: StaffSupport = {};
try {
  const raw = fs.readFileSync('src/data/staff-support.json', 'utf-8');
  staffSupport = JSON.parse(raw) as StaffSupport;
} catch {
  // graceful degradation
}
const staffList: StaffPerson[] = staffSupport.maintainers ?? [];

let events: MemberEvent[] = [];
try {
  const raw = fs.readFileSync('src/data/changelog.json', 'utf-8');
  events = JSON.parse(raw) as MemberEvent[];
} catch {
  // graceful degradation on fresh clone
}
const memberBySlug = new Map(members.map(m => [m.slug, m]));

let architectures: SafeArchitecture[] = [];
try {
  const raw = fs.readFileSync('src/data/architectures.json', 'utf-8');
  architectures = JSON.parse(raw) as SafeArchitecture[];
} catch {
  // graceful degradation — architectures tab will show empty state
}

const totalFunding = members.reduce((sum, m) => sum + (m.totalFunding ?? 0), 0);
const platinumCount = members.filter(m => m.tier === 'Platinum').length;
const goldCount = members.filter(m => m.tier === 'Gold').length;
const silverCount = members.filter(m => m.tier === 'Silver').length;
const industries = [...new Set(members.flatMap(m => m.industries ?? []).filter(Boolean))].sort();
const countries = [...new Set(members.map(m => m.country).filter(Boolean))].sort() as string[];
const heroSets = selectHeroSets(members);

// Arch stats — computed at build time from architectures.json.
const archRefTypes = [...new Set(architectures.flatMap(a => a.refArchTypes ?? []))].sort();
const archIndustryList = [...new Set(architectures.flatMap(a => a.industries ?? []))].sort();
const archProjectNames = new Set(architectures.flatMap(a => (a.projects ?? []).map(p => p.name)));
const archIndustryCount = archIndustryList.length;
const archProjectCount = archProjectNames.size;

const STATIC_COUNT = 30;
const staticMembers = members.slice(0, STATIC_COUNT);
---
<EndusersLayout
  title="CNCF End Users"
  memberCount={members.length}
  platinumCount={platinumCount}
  goldCount={goldCount}
  silverCount={silverCount}
  totalFunding={totalFunding}
  industries={industries}
  countries={countries}
  archCount={architectures.length}
  archRefTypes={archRefTypes}
  archIndustryList={archIndustryList}
  archIndustryCount={archIndustryCount}
  archProjectCount={archProjectCount}
>
  <div slot="heroes">
    <section class="heroes-section" aria-label="Daily highlights">
      {(Object.entries(heroSets) as [string, SafeMember[]][]).map(([tabKey, heroes]) => (
        <div class="heroes-grid" data-heroes-tab={tabKey} style={tabKey !== 'everyone' ? 'display:none' : ''}>
          {heroes.map(member => (
            <Fragment set:html={renderShowcaseCard(member)} />
          ))}
        </div>
      ))}
    </section>

    {staffList.length > 0 && (
      <section class="staff-support-section">
        <h2 class="staff-support-heading">CNCF Staff providing Support</h2>
        <div class="staff-support-list">
          {staffList.map(m => (
            <a href={m.handle ? `https://github.com/${m.handle}` : (m.profileUrl ?? '#')} target="_blank" rel="noopener noreferrer" class="staff-support-card">
              <img
                src={m.handle ? `https://avatars.githubusercontent.com/${m.handle}` : (m.imageUrl ?? '')}
                alt={m.name}
                class="staff-support-avatar"
                loading="lazy"
              />
              <div class="staff-support-info">
                <span class="staff-support-name">{m.name}</span>
                {m.handle && <span class="staff-support-handle">@{m.handle}</span>}
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    {events.length > 0 && (
      <section id="changelog-section" aria-label="Member activity">
        <h2 class="changelog-heading">Member Activity</h2>
        {events.slice(0, 20).map(event => (
          <Fragment set:html={renderChangelogEvent(event, memberBySlug.get(event.memberSlug))} />
        ))}
      </section>
    )}
  </div>

  {staticMembers.map(m => <Fragment set:html={renderCard(m)} />)}

  <Fragment slot="architectures">
    <div class="arch-intro">
      <p>These organizations didn't just adopt cloud native — they published how. Each architecture
      is a collaboration between an end user, CNCF projects, and the people who built them.</p>
    </div>
    {architectures.length > 0
      ? architectures.map(a => <Fragment set:html={renderArchCard(a)} />)
      : <div class="arch-empty">
          <p>No reference architectures loaded yet.</p>
          <a href="https://architecture.cncf.io/architectures/?all=true" target="_blank" rel="noopener noreferrer">
            Browse architectures on architecture.cncf.io →
          </a>
        </div>
    }
  </Fragment>
</EndusersLayout>

<script>
  import { initSearch, searchMembers, getAllMembers } from '../lib/search';
  import { initArchSearch, searchArchSlugs, resetArchSearch } from '../lib/arch-search';
  import { renderCard } from '../lib/member-renderer';
  import { initTabs, filterByTab } from '../lib/tabs';
  import { initKeyboard, tabFromNumber } from '../lib/keyboard';
  import { fireFountain, preloadOnHover, fireHearts } from '../lib/confetti';
  import { openArchModal, initArchModal } from '../lib/arch-modal';
  import type { TabId } from '../lib/tabs';

  const base = import.meta.env.BASE_URL;
  const grid = document.getElementById('members-grid')!;
  const noResults = document.getElementById('no-results')!;
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const searchCount = document.getElementById('search-count')!;
  const statShowing = document.getElementById('stat-showing')!;

  let allMembers: import('../lib/member-renderer').SafeMember[] = [];
  let currentTab: TabId = 'everyone';
  let currentQuery = '';
  let currentIndustry = '';
  let currentRegion = '';

  async function loadAllMembers() {
    try {
      const res = await fetch(`${base}/data/members.json`);
      allMembers = await res.json();
      initSearch(allMembers);
      applyFilters();
    } catch {
      // use static members already rendered
    }
  }

  function applyFilters() {
    // ── Arch tab — own grid, own search, own filters ──────────────────────
    if (currentTab === 'architectures') {
      const slugMatches = searchArchSlugs(currentQuery);
      const archRefTypeFilter = (document.getElementById('arch-reftype-filter') as HTMLSelectElement | null)?.value ?? '';
      const archIndustryFilter = (document.getElementById('arch-industry-filter') as HTMLSelectElement | null)?.value ?? '';

      let visibleCount = 0;
      document.querySelectorAll<HTMLElement>('.arch-card[data-slug]').forEach(card => {
        const slug = card.dataset.slug ?? '';
        const industries = card.dataset.industries ?? '';
        const reftypes = card.dataset.reftypes ?? '';

        const passesSearch = slugMatches === null || slugMatches.has(slug);
        const passesType = !archRefTypeFilter || reftypes.split(',').map(s => s.trim()).includes(archRefTypeFilter);
        const passesIndustry = !archIndustryFilter || industries.split(',').map(s => s.trim()).includes(archIndustryFilter);

        const visible = passesSearch && passesType && passesIndustry;
        card.style.display = visible ? '' : 'none';
        if (visible) visibleCount++;
      });

      searchCount.textContent = currentQuery ? String(visibleCount) : '';
      grid.style.display = 'none';
      noResults.style.display = 'none';
      return;
    }

    // ── Member tabs ───────────────────────────────────────────────────────
    // architectures tab has its own grid — member filters don't apply
    let filtered = filterByTab(allMembers, currentTab);
    if (currentQuery.trim()) {
      const results = searchMembers(currentQuery);
      const slugSet = new Set(results.map(r => r.slug));
      filtered = filtered.filter(m => slugSet.has(m.slug));
    }
    if (currentIndustry) {
      filtered = filtered.filter(m => (m.industries ?? []).includes(currentIndustry));
    }
    if (currentRegion) {
      filtered = filtered.filter(m => m.country === currentRegion);
    }
    if (filtered.length === 0 && (currentQuery || currentTab !== 'everyone')) {
      grid.style.display = 'none';
      noResults.style.display = 'block';
      searchCount.textContent = '';
      statShowing.textContent = '0';
    } else {
      noResults.style.display = 'none';
      grid.style.display = '';
      grid.innerHTML = filtered.map(renderCard).join('\n');
      wireCardEvents();
      const label = String(filtered.length);
      statShowing.textContent = label;
      searchCount.textContent = currentQuery ? String(filtered.length) : '';
    }
  }

  function showHeroesForTab(tab: string) {
    const heroesSection = document.querySelector<HTMLElement>('.heroes-section');
    const staffSection = document.querySelector<HTMLElement>('.staff-support-section');
    const changelogSection = document.querySelector<HTMLElement>('#changelog-section');
    const archGrid = document.getElementById('arch-grid');
    const membersGrid = document.getElementById('members-grid');
    const memberSidebar = document.getElementById('member-sidebar-sections');
    const archSidebar = document.getElementById('arch-sidebar-sections');

    const isArchTab = tab === 'architectures';

    // Arch tab: show arch grid + arch sidebar, hide member grid + member sidebar + heroes.
    if (archGrid) archGrid.style.display = isArchTab ? 'grid' : 'none';
    if (membersGrid) membersGrid.style.display = isArchTab ? 'none' : '';
    if (memberSidebar) memberSidebar.style.display = isArchTab ? 'none' : '';
    if (archSidebar) archSidebar.style.display = isArchTab ? '' : 'none';
    if (heroesSection) heroesSection.style.display = isArchTab ? 'none' : '';
    if (staffSection) staffSection.style.display = isArchTab ? 'none' : '';
    if (changelogSection) changelogSection.style.display = (isArchTab || tab !== 'everyone') ? 'none' : '';

    // Swap search placeholder and reset arch filters when leaving the arch tab.
    if (searchInput) {
      searchInput.placeholder = isArchTab ? 'Search architectures... (/)' : 'Search members... (/)';
      searchInput.setAttribute('aria-label', isArchTab ? 'Search architectures' : 'Search members');
    }
    if (!isArchTab) {
      const reftypeSelect = document.getElementById('arch-reftype-filter') as HTMLSelectElement | null;
      const industrySelect = document.getElementById('arch-industry-filter') as HTMLSelectElement | null;
      if (reftypeSelect) reftypeSelect.value = '';
      if (industrySelect) industrySelect.value = '';
      // Rebuild arch index on next visit (cards may have had display toggled).
      resetArchSearch();

      const heroKey = ['platinum', 'gold', 'silver', 'academic'].includes(tab) ? tab : 'everyone';
      document.querySelectorAll<HTMLElement>('.heroes-grid[data-heroes-tab]').forEach(g => {
        g.style.display = g.dataset.heroesTab === heroKey ? 'grid' : 'none';
      });
    }
  }

  initTabs((tabId) => { currentTab = tabId; showHeroesForTab(tabId); applyFilters(); });

  searchInput?.addEventListener('input', () => {
    currentQuery = searchInput.value;
    applyFilters();
  });

  const visibleCards = () =>
    Array.from(document.querySelectorAll<HTMLElement>('.member-card, .hero-card, .arch-card'))
      .filter(c => c.offsetParent !== null && c.style.display !== 'none');

  let focusedIdx = -1;

  function resetFocus() {
    document.querySelectorAll('.keyboard-focused')
      .forEach(c => c.classList.remove('keyboard-focused'));
    focusedIdx = -1;
  }

  function focusCard(idx: number) {
    const all = visibleCards();
    if (all.length === 0) return;
    focusedIdx = Math.max(0, Math.min(idx, all.length - 1));
    all.forEach((c, i) => c.classList.toggle('keyboard-focused', i === focusedIdx));
    all[focusedIdx].scrollIntoView({ block: 'nearest', behavior: 'smooth' });
    const liveRegion = document.getElementById('kbd-live-region');
    if (liveRegion) {
      const name = all[focusedIdx].querySelector('.card-name, .member-name, .hero-name, .showcase-name, h3, h4')?.textContent ?? '';
      liveRegion.textContent = `Focused: ${name}`;
    }
  }

  document.querySelectorAll('.section-link[data-tab]').forEach(btn => {
    btn.addEventListener('click', resetFocus);
  });

  initKeyboard({
    onSearch: () => searchInput?.focus(),
    onHelp: () => {
      document.getElementById('keyboard-help-modal')?.classList.add('visible');
      document.getElementById('keyboard-help-backdrop')?.classList.add('visible');
    },
    onTheme: () => { const btn = document.getElementById('theme-toggle') as HTMLButtonElement; btn?.click(); },
    onTab: (n) => {
      const tab = tabFromNumber(n);
      const btn = document.querySelector(`.section-link[data-tab="${tab}"]`) as HTMLButtonElement;
      btn?.click();
    },
    onEscape: () => {
      // arch-modal: fix #1 — if the arch modal is open, let the native <dialog>
      // handle Escape (it closes the modal); don't also clear search or reset focus.
      const archModal = document.getElementById('arch-modal') as HTMLDialogElement | null;
      if (archModal?.open) return;

      if (searchInput && searchInput.value) {
        searchInput.value = '';
        currentQuery = '';
        applyFilters();
      }
      resetFocus();
    },
    onNext: () => { focusCard(focusedIdx + 1); },
    onPrev: () => { focusCard(focusedIdx - 1); },
    onOpenLink: () => {
      const all = visibleCards();
      const card = all[focusedIdx];
      if (!card) return;
      // arch-modal: fix #1 — arch cards open a modal, not a link.
      if (card.classList.contains('arch-card')) {
        const slug = (card as HTMLElement).dataset.slug;
        if (slug) openArchModal(slug);
        return;
      }
      const link = card?.querySelector('a[href]') as HTMLAnchorElement | null;
      if (link) { window.open(link.href, '_blank', 'noopener'); }
    },
    onSitePrev: () => {
      const isLocal = window.location.hostname === 'localhost';
      window.location.href = isLocal
        ? 'http://localhost:4322/projects-website/'
        : 'https://castrojo.github.io/projects-website/';
    },
    onSiteNext: () => {
      const isLocal = window.location.hostname === 'localhost';
      window.location.href = isLocal
        ? 'http://localhost:4323/people-website/'
        : 'https://castrojo.github.io/people-website/';
    },
  });

  function wireCardEvents(): void {
    document.querySelectorAll<HTMLElement>('.member-card').forEach(card => {
      preloadOnHover(card);
      card.addEventListener('click', () => fireFountain(card));
    });
    document.querySelectorAll<HTMLElement>('.hero-card').forEach(card => {
      preloadOnHover(card);
      card.addEventListener('click', () => fireHearts(card));
    });
    document.querySelectorAll<HTMLElement>('.arch-card').forEach(card => {
      const slug = card.dataset.slug;
      if (!slug) return;
      card.addEventListener('click', () => openArchModal(slug));
      card.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          openArchModal(slug);
        }
      });
    });
  }

  loadAllMembers();
  wireCardEvents();
  initArchModal();

  document.getElementById('industry-filter')?.addEventListener('change', (e) => {
    currentIndustry = (e.target as HTMLSelectElement).value;
    applyFilters();
  });

  document.getElementById('region-filter')?.addEventListener('change', (e) => {
    currentRegion = (e.target as HTMLSelectElement).value;
    applyFilters();
  });

  document.getElementById('arch-reftype-filter')?.addEventListener('change', () => applyFilters());
  document.getElementById('arch-industry-filter')?.addEventListener('change', () => applyFilters());
</script>
