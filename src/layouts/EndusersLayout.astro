---
import ThemeToggle from '../components/ThemeToggle.astro';
import KeyboardHelp from '../components/KeyboardHelp.astro';
import SiteSwitcher from '../components/SiteSwitcher.astro';
import KubeConBanner from '../components/KubeConBanner.astro';
import InfoBox from '../components/InfoBox.astro';
import { getActiveBanners } from '../lib/banners';

interface Props {
  title: string;
  description?: string;
  memberCount?: number;
  endUserCount?: number;
  totalFunding?: number;
  industries?: string[];
  countries?: string[];
}
const { title, description = 'CNCF End Users and member organizations', memberCount = 0, endUserCount = 0, totalFunding = 0, industries = [], countries = [] } = Astro.props;
const banners = await getActiveBanners();
const base = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" href={`${base}/cncf-icon-color.svg`} type="image/svg+xml" />
  <link rel="alternate" type="application/rss+xml" title="CNCF Members Feed" href={`${base}/feed.xml`} />
  <script is:inline>
    (function() {
      const getTheme = () => {
        const stored = localStorage.getItem('theme');
        if (stored === 'light' || stored === 'dark') return stored;
        if (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) return 'dark';
        return 'light';
      };
      document.documentElement.setAttribute('data-theme', getTheme());
    })();
  </script>
  <style is:global>
    :root {
      --color-bg-default: #ffffff; --color-bg-secondary: #f6f8fa; --color-bg-tertiary: #eaeef2;
      --color-border-default: #d0d7de; --color-text-primary: #24292f; --color-text-secondary: #57606a;
      --color-text-muted: #8c959f; --color-cncf-blue: #0086FF; --color-rss-orange: #f26522;
      --color-platinum: #E5E4E2; --color-gold: #FFB300; --color-silver: #C0C0C0;
      --color-enduser: #0086FF; --color-academic: #7B2FBE; --color-nonprofit: #00A86B;
    }
    [data-theme="dark"] {
      --color-bg-default: #0d1117; --color-bg-secondary: #161b22; --color-bg-tertiary: #21262d;
      --color-border-default: #30363d; --color-text-primary: #e6edf3; --color-text-secondary: #8b949e;
      --color-text-muted: #6e7681; --color-cncf-blue: #58a6ff;
    }
    * { box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif; background: var(--color-bg-secondary); color: var(--color-text-primary); margin: 0; line-height: 1.5; }
    .container { max-width: 1400px; margin: 0 auto; padding: 0 1.5rem; }
    .site-header { position: sticky; top: 0; z-index: 100; background: var(--color-bg-default); border-bottom: 1px solid var(--color-border-default); }
    .header-inner { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; padding: 0.75rem 0; }
    .header-left { display: flex; align-items: center; gap: 1rem; flex: 1; flex-wrap: wrap; }
    .logo-title { display: flex; align-items: center; gap: 0.75rem; }
    .cncf-logo-wrapper { display: flex; align-items: center; flex-shrink: 0; }
    .cncf-logo-wrapper .logo-light { display: block; }
    .cncf-logo-wrapper .logo-dark { display: none; }
    [data-theme="dark"] .cncf-logo-wrapper .logo-light { display: none; }
    [data-theme="dark"] .cncf-logo-wrapper .logo-dark { display: block; }
    .title-block { display: flex; flex-direction: column; gap: 0.1rem; }
    h1.site-title { font-size: 1rem; font-weight: 600; color: var(--color-text-primary); margin: 0; }
    .home-link { color: inherit; text-decoration: none; white-space: nowrap; }
    .site-subtitle { margin: 0; font-size: 0.7rem; color: var(--color-text-muted); font-style: italic; transition: opacity 0.6s ease; white-space: nowrap; }
    .site-subtitle.fade { opacity: 0; }
    .search-wrapper { position: relative; }
    #search-input { width: 220px; padding: 0.375rem 0.75rem; border: 1px solid var(--color-border-default); border-radius: 6px; background: var(--color-bg-secondary); color: var(--color-text-primary); font-size: 0.875rem; }
    #search-input:focus { outline: none; border-color: var(--color-cncf-blue); box-shadow: 0 0 0 3px rgba(0,134,255,.15); }
    .search-count { position: absolute; right: 0.5rem; top: 50%; transform: translateY(-50%); font-size: 0.75rem; color: var(--color-text-muted); pointer-events: none; }
    .header-actions { display: flex; align-items: center; gap: 0.5rem; }
    .keyboard-help-button { background: none; border: 1px solid var(--color-border-default); border-radius: 6px; padding: 0.4rem 0.6rem; cursor: pointer; font-size: 0.875rem; color: var(--color-text-secondary); }
    .keyboard-help-button:hover { color: var(--color-text-primary); background: var(--color-bg-secondary); }
    .section-nav { display: flex; gap: 0; overflow-x: auto; scrollbar-width: none; padding: 0; border-top: 1px solid var(--color-border-default); }
    .section-nav::-webkit-scrollbar { display: none; }
    .section-link { padding: 0.625rem 1rem; font-size: 0.875rem; font-weight: 500; color: var(--color-text-secondary); background: none; border: none; border-bottom: 2px solid transparent; cursor: pointer; white-space: nowrap; transition: color 0.15s, border-color 0.15s; }
    .section-link:hover { color: var(--color-text-primary); }
    .section-link.active { color: var(--color-cncf-blue); border-bottom-color: var(--color-cncf-blue); font-weight: 600; }
    .page-layout { display: grid; grid-template-columns: 300px 1fr; gap: 2rem; align-items: start; max-width: 1400px; margin: 0 auto; padding: 1.5rem; }
    .heroes-section { margin-bottom: 1.5rem; }
    .heroes-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 1rem; }
    .hero-card { background: var(--color-bg-default); border: 2px solid var(--card-accent, var(--color-cncf-blue)); border-radius: 8px; padding: 1rem; display: flex; gap: 0.75rem; align-items: flex-start; }
    .hero-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-text-muted); margin-bottom: 0.25rem; }
    .hero-name { font-size: 0.9rem; font-weight: 600; color: var(--color-text-primary); }
    .hero-logo { width: 36px; height: 36px; object-fit: contain; flex-shrink: 0; }
    .type-badge { font-size: 0.65rem; padding: 0.1rem 0.4rem; border-radius: 4px; background: var(--color-bg-secondary); color: var(--color-text-secondary); border: 1px solid var(--color-border-default); margin-left: 0.25rem; }
    .card-ticker { font-family: ui-monospace, monospace; font-size: 0.75rem; color: var(--color-text-muted); }
    .card-region { font-size: 0.78rem; color: var(--color-text-muted); font-style: italic; }
    .hero-content { display: flex; flex-direction: column; gap: 0.15rem; flex: 1; min-width: 0; }
    .hero-description { font-size: 0.72rem; color: var(--color-text-secondary); line-height: 1.3; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; margin: 0; }
    .hero-meta { display: flex; gap: 0.5rem; font-size: 0.68rem; color: var(--color-text-muted); flex-wrap: wrap; }
    .hero-tier { font-weight: 600; }
    a.hero-name { color: var(--color-text-primary); text-decoration: none; font-size: 0.9rem; font-weight: 600; }
    a.hero-name:hover { color: var(--color-cncf-blue); text-decoration: underline; }
    .hero-logo { width: 48px; height: 48px; }
    .stats-box { background: var(--color-bg-default); border: 1px solid var(--color-border-default); border-radius: 6px; padding: 1rem; }
    .sidebar-heading { font-size: 0.875rem; font-weight: 600; margin: 0 0 0.75rem; }
    .stat-row { display: flex; justify-content: space-between; align-items: center; padding: 0.25rem 0; font-size: 0.875rem; }
    .stat-label { color: var(--color-text-secondary); }
    .stat-value { font-weight: 600; color: var(--color-text-primary); }
    .members-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1rem; }
    .member-card { background: var(--color-bg-default); border: 1px solid var(--color-border-default); border-top: 3px solid var(--card-accent, var(--color-border-default)); border-radius: 6px; padding: 1rem; transition: box-shadow 0.15s; }
    .member-card:hover { box-shadow: 0 4px 12px rgba(0,0,0,.1); }
    .card-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.75rem; }
    .tier-badge { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; padding: 0.2rem 0.5rem; border-radius: 4px; }
    .card-logo { border-radius: 4px; }
    .card-name { font-size: 0.95rem; font-weight: 600; color: var(--color-text-primary); margin: 0 0 0.5rem; }
    .card-description { font-size: 0.8rem; color: var(--color-text-secondary); margin: 0 0 0.5rem; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
    .card-meta-row { font-size: 0.78rem; color: var(--color-text-muted); margin-bottom: 0.2rem; }
    .card-category { font-style: italic; }
    .card-links { display: flex; gap: 0.5rem; margin-top: 0.75rem; flex-wrap: wrap; }
    .card-link { font-size: 0.78rem; color: var(--color-cncf-blue); text-decoration: none; padding: 0.2rem 0.5rem; border: 1px solid var(--color-border-default); border-radius: 4px; }
    .card-link:hover { background: var(--color-bg-secondary); }
    .sidebar { display: flex; flex-direction: column; gap: 1.5rem; }
    .no-results { text-align: center; padding: 3rem 1rem; color: var(--color-text-secondary); grid-column: 1 / -1; }
    .filter-box { background: var(--color-bg-default); border: 1px solid var(--color-border-default); border-radius: 6px; padding: 1rem; }
    .category-select { width: 100%; padding: 0.375rem 0.5rem; border: 1px solid var(--color-border-default); border-radius: 6px; background: var(--color-bg-secondary); color: var(--color-text-primary); font-size: 0.875rem; cursor: pointer; }
    .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0; }
    @media (max-width: 900px) {
      .page-layout { grid-template-columns: 1fr; }
      .sidebar { order: -1; }
      .heroes-grid { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 600px) {
      .site-header .container { padding: 0 1rem; }
      .page-layout { padding: 1rem; }
      .heroes-grid { grid-template-columns: 1fr; }
      #search-input { width: 160px; }
    }
  </style>
</head>
<body>
  <header class="site-header">
    <div class="container">
      <div class="header-inner">
        <div class="header-left">
          <div class="logo-title">
            <span class="cncf-logo-wrapper" aria-hidden="true">
              <img src={`${base}/cncf-icon-color.svg`} alt="CNCF" class="logo-light" width="56" height="56" />
              <img src={`${base}/cncf-icon-white.svg`} alt="CNCF" class="logo-dark" width="56" height="56" />
            </span>
            <div class="title-block">
              <h1 class="site-title">
                <a href={base} class="home-link">CNCF End Users</a>
              </h1>
              <p class="site-subtitle" id="rotating-slogan" aria-live="polite">Built for the love of the game</p>
            </div>
            <SiteSwitcher activeSite="endusers" />
          </div>
          <div class="search-wrapper">
            <input id="search-input" type="search" placeholder="Search members... (/)" aria-label="Search members" />
            <span class="search-count" id="search-count"></span>
          </div>
        </div>
        <div class="header-actions">
          <ThemeToggle />
          <button id="help-button" class="keyboard-help-button" aria-label="Keyboard shortcuts" title="Keyboard shortcuts (Press ?)">?</button>
        </div>
      </div>
      <nav class="section-nav" aria-label="Filter by tier">
        <button class="section-link active" data-tab="everyone">Everyone</button>
        <button class="section-link" data-tab="end-users">End Users</button>
        <button class="section-link" data-tab="platinum">Platinum</button>
        <button class="section-link" data-tab="gold">Gold</button>
        <button class="section-link" data-tab="silver">Silver</button>
        <button class="section-link" data-tab="academic">Academic &amp; Nonprofit</button>
      </nav>
    </div>
  </header>

  <div class="page-layout">
    <aside class="sidebar">
      <div class="stats-box">
        <h2 class="sidebar-heading">Members</h2>
        <div class="stat-row"><span class="stat-label">Total members</span><span class="stat-value" id="stat-total">{memberCount}</span></div>
        <div class="stat-row"><span class="stat-label">End users</span><span class="stat-value" id="stat-endusers">{endUserCount}</span></div>
        <div class="stat-row"><span class="stat-label">Showing</span><span class="stat-value" id="stat-showing"></span></div>
        {totalFunding > 0 && (
          <div class="stat-row"><span class="stat-label">Total funding</span><span class="stat-value">${Math.round(totalFunding / 1e9)}B+</span></div>
        )}
      </div>
      {industries.length > 0 && (
        <div class="filter-box">
          <h2 class="sidebar-heading">Filter by Industry</h2>
          <select id="industry-filter" class="category-select" aria-label="Filter by industry">
            <option value="">All industries</option>
            {industries.map(ind => <option value={ind}>{ind}</option>)}
          </select>
        </div>
      )}
      <div class="filter-box">
        <h2 class="sidebar-heading">Filter by Region</h2>
        <select id="region-filter" class="category-select" aria-label="Filter by region">
          <option value="">All regions</option>
          {countries.map(c => <option value={c}>{c}</option>)}
        </select>
      </div>
      <InfoBox
        title="About CNCF Members"
        description="Organizations that support the cloud native ecosystem through CNCF membership."
        links={[
          { text: 'CNCF Landscape', url: 'https://landscape.cncf.io', external: true },
          { text: 'Become a Member', url: 'https://www.cncf.io/about/join/', external: true },
          { text: 'Members Feed (RSS)', url: `${base}/feed.xml`, rss: true },
        ]}
      />
      {banners.length > 0 && <KubeConBanner banners={banners} />}
    </aside>
    <div class="main-content">
      <slot name="heroes" />
      <div id="members-grid" class="members-grid">
        <slot />
      </div>
      <div id="no-results" class="no-results" style="display:none">No members match your search.</div>
    </div>
  </div>

  <KeyboardHelp />

  <div id="kbd-live-region" aria-live="polite" aria-atomic="true" class="sr-only"></div>

  <script>
    document.getElementById('help-button')?.addEventListener('click', () => {
      const modal = document.getElementById('keyboard-help-modal');
      if (modal) {
        modal.classList.add('visible');
        document.getElementById('keyboard-help-backdrop')?.classList.add('visible');
      }
    });
  </script>

  <script>
    const SLOGANS = [
      "Built for the love of the game",
      "Welcome to indie cloud native",
      "Built for the love of the game. Welcome to indie cloud native",
      "Discover the CNCF cloud native ecosystem",
      "Community-driven, community-powered",
    ];
    const slogan = document.getElementById('rotating-slogan');
    if (slogan) {
      let idx = 0;
      setInterval(() => {
        slogan.classList.add('fade');
        setTimeout(() => {
          idx = (idx + 1) % SLOGANS.length;
          slogan.textContent = SLOGANS[idx];
          slogan.classList.remove('fade');
        }, 600);
      }, 12000);
    }
  </script>
</body>
</html>
